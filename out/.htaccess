<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Skip if file or directory already exists
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Map /modulos -> modulos.html
  RewriteRule ^modulos/?$ modulos.html [L]

  # Map /suporte -> suporte.html
  RewriteRule ^suporte/?$ suporte.html [L]

  # Map /atualizacoes -> atualizacoes.html
  RewriteRule ^atualizacoes/?$ atualizacoes.html [L]

  # Map /atualizacoes/<id> -> atualizacoes/<id>.html
  RewriteRule ^atualizacoes/([a-zA-Z0-9-]+)/?$ atualizacoes/$1.html [L]

  # Fallback: try adding .html extension
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L]

  # Final fallback to index.html (for 404s)
  RewriteRule ^ index.html [L]
</IfModule>
