7:["$","$L12",null,{"update":{"id":"v0-0-5","version":"0.0.5","title":"Área Social, Documento 2.0 e otimização completa da plataforma","date":"2026-04-24","badge":"Atualização massiva","badgeColor":"bg-pink-500/20 text-pink-300 border-pink-500/30","heroImage":null,"summary":"A maior atualização até agora. Nova área Social com 3 módulos inéditos, reestruturação completa do Documento e otimizações em todos os módulos da plataforma.","changes":[{"type":"novo","text":"Nova área Social com 3 módulos: Rede, Projetos e Mensagens."},{"type":"novo","text":"Módulo Rede: envie e receba pedidos de amizade e veja um resumo do perfil de cada pessoa — projetos, trabalhos e mais."},{"type":"novo","text":"Módulo Projetos: explore projetos públicos do módulo de Portfólio de outros usuários."},{"type":"novo","text":"Módulo Mensagens: troca de mensagens 1×1 com suas conexões (beta). Chat global disponível nas notificações."},{"type":"novo","text":"Reestruturação completa do módulo Documento: capa personalizada, sumário automático, paginação e compartilhamento público."},{"type":"novo","text":"Biblioteca adicionada ao Link Público, exibindo todos os documentos públicos do usuário."},{"type":"novo","text":"No módulo de Portfólio, adicionada opção de favoritar itens e filtrar por favoritos."},{"type":"novo","text":"No módulo de Portfólio, adicionada opção de esconder capa e tags no projeto público."},{"type":"novo","text":"No módulo de Carreira, adicionado upload de currículo."},{"type":"melhoria","text":"Melhoria de infraestrutura e otimização de desempenho em todos os módulos da plataforma."},{"type":"melhoria","text":"Adicionadas animações em todos os módulos para uma experiência mais fluida."},{"type":"melhoria","text":"Link Público reformulado com novas animações e melhor aproveitamento de espaço."},{"type":"melhoria","text":"Cards de Notas, Cursos, Portfólio e Trabalhos redesenhados para melhor visualização."},{"type":"melhoria","text":"Melhorias gerais de segurança do sistema."},{"type":"correcao","text":"Corrigido problema com renovação automática de assinaturas."},{"type":"correcao","text":"Correção na geração de relatórios no módulo de Trabalhos."},{"type":"correcao","text":"Corrigida duplicação de itens de tópicos nos cards de Trabalhos."},{"type":"correcao","text":"Correção na criação de Roadmaps, separando corretamente os arquivos internos."},{"type":"correcao","text":"Corrigido bug onde ao excluir uma nota com evento vinculado, o evento permanecia no calendário."},{"type":"correcao","text":"Correção ao criar votações em Trabalhos."},{"type":"correcao","text":"Corrigido envio de e-mails com links quebrados."},{"type":"remocao","text":"Notificações push desabilitadas temporariamente para correções e melhorias futuras."}]}}]
