7:["$","$L12",null,{"update":{"id":"v0-0-3","version":"0.0.3","title":"Correções gerais e em Trabalhos","date":"2026-02-28","badge":"Correções","badgeColor":"bg-emerald-500/20 text-emerald-300 border-emerald-500/30","heroImage":null,"summary":"Versão focada em estabilidade. Correções no módulo de Trabalhos, no fluxo de tarefas filho e no sistema de renovação de assinaturas.","changes":[{"type":"correcao","text":"No módulo de Trabalhos, era possível criar uma tarefa filho de uma tarefa pai — corrigido para não permitir tarefas filhas de tarefas já filhas."},{"type":"correcao","text":"Na configuração de Assinaturas, a renovação não funcionava mesmo com pagamento correto — corrigido para renovar a assinatura corretamente."},{"type":"correcao","text":"No módulo de Trabalhos, diversas correções de bugs relacionados à criação, edição e exclusão de tarefas, sprints e backlog."}]}}]
